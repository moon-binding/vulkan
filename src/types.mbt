///|
/// MoonBit Vulkan SDK Bindings - Additional Types
/// Vulkan additional scalar and platform types

// Additional scalar types - use Int directly for size and mask values


// Flag types
pub type VkPipelineStageFlags = Int
pub type VkPipelineStageFlagBits = Int

pub type VkMemoryPropertyFlags = Int
pub type VkMemoryHeapFlags = Int
pub type VkQueueFlags = Int
pub type VkCommandPoolCreateFlags = Int
pub type VkCommandPoolResetFlags = Int
pub type VkCommandBufferUsageFlags = Int
pub type VkCommandBufferResetFlags = Int

// Pipeline stage flag bits
pub const VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT : Int = 0x00000001
pub const VK_PIPELINE_STAGE_DRAW_INDIRECT_BIT : Int = 0x00000002
pub const VK_PIPELINE_STAGE_VERTEX_INPUT_BIT : Int = 0x00000004
pub const VK_PIPELINE_STAGE_VERTEX_SHADER_BIT : Int = 0x00000008
pub const VK_PIPELINE_STAGE_TESSELLATION_CONTROL_SHADER_BIT : Int = 0x00000010
pub const VK_PIPELINE_STAGE_TESSELLATION_EVALUATION_SHADER_BIT : Int = 0x00000020
pub const VK_PIPELINE_STAGE_GEOMETRY_SHADER_BIT : Int = 0x00000040
pub const VK_PIPELINE_STAGE_FRAGMENT_SHADER_BIT : Int = 0x00000080
pub const VK_PIPELINE_STAGE_EARLY_FRAGMENT_TESTS_BIT : Int = 0x00000100
pub const VK_PIPELINE_STAGE_LATE_FRAGMENT_TESTS_BIT : Int = 0x00000200
pub const VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT : Int = 0x00000400
pub const VK_PIPELINE_STAGE_COMPUTE_SHADER_BIT : Int = 0x00000800
pub const VK_PIPELINE_STAGE_TRANSFER_BIT : Int = 0x00001000
pub const VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT : Int = 0x00002000
pub const VK_PIPELINE_STAGE_HOST_BIT : Int = 0x00004000
pub const VK_PIPELINE_STAGE_ALL_GRAPHICS_BIT : Int = 0x00008000
pub const VK_PIPELINE_STAGE_ALL_COMMANDS_BIT : Int = 0x00010000
pub const VK_PIPELINE_STAGE_TRANSFORM_FEEDBACK_BIT_EXT : Int = 0x00020000
pub const VK_PIPELINE_STAGE_CONDITIONAL_RENDERING_BIT_EXT : Int = 0x00040000
pub const VK_PIPELINE_STAGE_COMMAND_PREPROCESS_BIT_NV : Int = 0x00080000
pub const VK_PIPELINE_STAGE_RAY_TRACING_SHADER_BIT_KHR : Int = 0x00200000
pub const VK_PIPELINE_STAGE_ACCELERATION_STRUCTURE_BUILD_BIT_KHR : Int = 0x02000000
pub const VK_PIPELINE_STAGE_FRAGMENT_DENSITY_PROCESS_BIT_EXT : Int = 0x00800000
pub const VK_PIPELINE_STAGE_FRAGMENT_SHADING_RATE_ATTACHMENT_BIT_KHR : Int = 0x00400000
pub const VK_PIPELINE_STAGE_MESH_SHADER_BIT_NV : Int = 0x00100000
pub const VK_PIPELINE_STAGE_TASK_SHADER_BIT_NV : Int = 0x00080000
pub const VK_PIPELINE_STAGE_NONE_KHR : Int = 0

// Memory property flags
pub const VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT : Int = 0x00000001
pub const VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT : Int = 0x00000002
pub const VK_MEMORY_PROPERTY_HOST_COHERENT_BIT : Int = 0x00000004
pub const VK_MEMORY_PROPERTY_HOST_CACHED_BIT : Int = 0x00000008
pub const VK_MEMORY_PROPERTY_LAZILY_ALLOCATED_BIT : Int = 0x00000010
pub const VK_MEMORY_PROPERTY_PROTECTED_BIT : Int = 0x00000020
pub const VK_MEMORY_PROPERTY_DEVICE_COHERENT_BIT_AMD : Int = 0x00000040
pub const VK_MEMORY_PROPERTY_DEVICE_UNCACHED_BIT_AMD : Int = 0x00000080
pub const VK_MEMORY_PROPERTY_RDMA_CAPABLE_BIT_NV : Int = 0x00000100

// Memory heap flags
pub const VK_MEMORY_HEAP_DEVICE_LOCAL_BIT : Int = 0x00000001
pub const VK_MEMORY_HEAP_MULTI_INSTANCE_BIT : Int = 0x00000002

// Queue flags
pub const VK_QUEUE_GRAPHICS_BIT : Int = 0x00000001
pub const VK_QUEUE_COMPUTE_BIT : Int = 0x00000002
pub const VK_QUEUE_TRANSFER_BIT : Int = 0x00000004
pub const VK_QUEUE_SPARSE_BINDING_BIT : Int = 0x00000008
pub const VK_QUEUE_PROTECTED_BIT : Int = 0x00000010

// Command pool create flags
pub const VK_COMMAND_POOL_CREATE_TRANSIENT_BIT : Int = 0x00000001
pub const VK_COMMAND_POOL_CREATE_RESET_COMMAND_BUFFER_BIT : Int = 0x00000002
pub const VK_COMMAND_POOL_CREATE_PROTECTED_BIT : Int = 0x00000004

// Command buffer usage flags
pub const VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT : Int = 0x00000001
pub const VK_COMMAND_BUFFER_USAGE_RENDER_PASS_CONTINUE_BIT : Int = 0x00000002
pub const VK_COMMAND_BUFFER_USAGE_SIMULTANEOUS_USE_BIT : Int = 0x00000004

// Command buffer level
pub enum VkCommandBufferLevel {
  VK_COMMAND_BUFFER_LEVEL_PRIMARY
  VK_COMMAND_BUFFER_LEVEL_SECONDARY
}

// Command pool reset flags
pub const VK_COMMAND_POOL_RESET_RELEASE_RESOURCES_BIT : Int = 0x00000001

// Command buffer reset flags
pub const VK_COMMAND_BUFFER_RESET_RELEASE_RESOURCES_BIT : Int = 0x00000001
