///|
/// MoonBit Vulkan SDK Bindings - Enums
/// Vulkan enumeration types

// Image type
pub enum VkImageType {
  VK_IMAGE_TYPE_1D
  VK_IMAGE_TYPE_2D
  VK_IMAGE_TYPE_3D
  _VK_IMAGE_TYPE_MAX_ENUM
}

// Image tiling
pub enum VkImageTiling {
  VK_IMAGE_TILING_OPTIMAL
  VK_IMAGE_TILING_LINEAR
  _VK_IMAGE_TILING_MAX_ENUM
}

// Image usage flags (bitmask, represented as Int)
pub const VK_IMAGE_USAGE_TRANSFER_SRC_BIT : Int = 0x00000001
pub const VK_IMAGE_USAGE_TRANSFER_DST_BIT : Int = 0x00000002
pub const VK_IMAGE_USAGE_SAMPLED_BIT : Int = 0x00000004
pub const VK_IMAGE_USAGE_STORAGE_BIT : Int = 0x00000008
pub const VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT : Int = 0x00000010
pub const VK_IMAGE_USAGE_DEPTH_STENCIL_ATTACHMENT_BIT : Int = 0x00000020
pub const VK_IMAGE_USAGE_TRANSIENT_ATTACHMENT_BIT : Int = 0x00000040
pub const VK_IMAGE_USAGE_INPUT_ATTACHMENT_BIT : Int = 0x00000080
pub const VK_IMAGE_USAGE_FRAGMENT_DENSITY_MAP_BIT_EXT : Int = 0x00000100
pub const VK_IMAGE_USAGE_FRAGMENT_SHADING_RATE_ATTACHMENT_BIT_KHR : Int = 0x00000200
pub const VK_IMAGE_USAGE_ATTACHMENT_FEEDBACK_LOOP_BIT_EXT : Int = 0x00000400

// Image create flags
pub const VK_IMAGE_CREATE_SPARSE_BINDING_BIT : Int = 0x00000001
pub const VK_IMAGE_CREATE_SPARSE_RESIDENCY_BIT : Int = 0x00000002
pub const VK_IMAGE_CREATE_SPARSE_ALIASED_BIT : Int = 0x00000004
pub const VK_IMAGE_CREATE_MUTABLE_FORMAT_BIT : Int = 0x00000008
pub const VK_IMAGE_CREATE_CUBE_COMPATIBLE_BIT : Int = 0x00000010
pub const VK_IMAGE_CREATE_ALIAS_BIT : Int = 0x00000400
pub const VK_IMAGE_CREATE_SPLIT_INSTANCE_BIND_REGIONS_BIT : Int = 0x00000040
pub const VK_IMAGE_CREATE_2D_ARRAY_COMPATIBLE_BIT : Int = 0x00000020
pub const VK_IMAGE_CREATE_BLOCK_TEXEL_VIEW_COMPATIBLE_BIT : Int = 0x00000080
pub const VK_IMAGE_CREATE_EXTENDED_USAGE_BIT : Int = 0x00000100
pub const VK_IMAGE_CREATE_PROTECTED_BIT : Int = 0x00000800
pub const VK_IMAGE_CREATE_DISJOINT_BIT : Int = 0x00000200
pub const VK_IMAGE_CREATE_CORNER_SAMPLED_BIT_NV : Int = 0x00002000
pub const VK_IMAGE_CREATE_SAMPLE_LOCATIONS_COMPATIBLE_DEPTH_BIT_EXT : Int = 0x00001000
pub const VK_IMAGE_CREATE_SUBSAMPLED_BIT_EXT : Int = 0x00004000
pub const VK_IMAGE_CREATE_SPLIT_INSTANCE_BIND_REGIONS_BIT_KHR : Int = 0x00000040
pub const VK_IMAGE_CREATE_2D_ARRAY_COMPATIBLE_BIT_KHR : Int = 0x00000020
pub const VK_IMAGE_CREATE_BLOCK_TEXEL_VIEW_COMPATIBLE_BIT_KHR : Int = 0x00000080
pub const VK_IMAGE_CREATE_EXTENDED_USAGE_BIT_KHR : Int = 0x00000100
pub const VK_IMAGE_CREATE_DISJOINT_BIT_KHR : Int = 0x00000200
pub const VK_IMAGE_CREATE_ALIAS_BIT_KHR : Int = 0x00000400

