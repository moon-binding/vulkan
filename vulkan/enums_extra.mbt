///|
/// MoonBit Vulkan SDK Bindings - Additional Enums
/// Additional Vulkan enumeration types

// Buffer usage flags
pub const VK_BUFFER_USAGE_TRANSFER_SRC_BIT : Int = 0x00000001
pub const VK_BUFFER_USAGE_TRANSFER_DST_BIT : Int = 0x00000002
pub const VK_BUFFER_USAGE_UNIFORM_TEXEL_BUFFER_BIT : Int = 0x00000004
pub const VK_BUFFER_USAGE_STORAGE_TEXEL_BUFFER_BIT : Int = 0x00000008
pub const VK_BUFFER_USAGE_UNIFORM_BUFFER_BIT : Int = 0x00000010
pub const VK_BUFFER_USAGE_STORAGE_BUFFER_BIT : Int = 0x00000020
pub const VK_BUFFER_USAGE_INDEX_BUFFER_BIT : Int = 0x00000040
pub const VK_BUFFER_USAGE_VERTEX_BUFFER_BIT : Int = 0x00000080
pub const VK_BUFFER_USAGE_INDIRECT_BUFFER_BIT : Int = 0x00000100
pub const VK_BUFFER_USAGE_CONDITIONAL_RENDERING_BIT_EXT : Int = 0x00000200
pub const VK_BUFFER_USAGE_RAY_TRACING_BIT_NV : Int = 0x00000400
pub const VK_BUFFER_USAGE_TRANSFORM_FEEDBACK_BUFFER_BIT_EXT : Int = 0x00000800
pub const VK_BUFFER_USAGE_TRANSFORM_FEEDBACK_COUNTER_BUFFER_BIT_EXT : Int = 0x00001000
pub const VK_BUFFER_USAGE_VIDEO_DECODE_SRC_BIT_KHR : Int = 0x00002000
pub const VK_BUFFER_USAGE_VIDEO_DECODE_DST_BIT_KHR : Int = 0x00004000
pub const VK_BUFFER_USAGE_VIDEO_ENCODE_SRC_BIT_KHR : Int = 0x00008000
pub const VK_BUFFER_USAGE_VIDEO_ENCODE_DST_BIT_KHR : Int = 0x00010000
pub const VK_BUFFER_USAGE_SHADER_BINDING_TABLE_BIT_KHR : Int = 0x00000400
pub const VK_BUFFER_USAGE_ACCELERATION_STRUCTURE_BUILD_INPUT_READ_ONLY_BIT_KHR : Int = 0x00020000
pub const VK_BUFFER_USAGE_ACCELERATION_STRUCTURE_STORAGE_BIT_KHR : Int = 0x00040000
pub const VK_BUFFER_USAGE_SHADER_DEVICE_ADDRESS_BIT : Int = 0x000200000
pub const VK_BUFFER_USAGE_MICROMAP_BUILD_INPUT_READ_ONLY_BIT_EXT : Int = 0x00100000
pub const VK_BUFFER_USAGE_MICROMAP_STORAGE_BIT_EXT : Int = 0x00200000
pub const VK_BUFFER_USAGE_PREPROCESS_BIT_NV : Int = 0x00200000

// Buffer create flags
pub const VK_BUFFER_CREATE_SPARSE_BINDING_BIT : Int = 0x00000001
pub const VK_BUFFER_CREATE_SPARSE_RESIDENCY_BIT : Int = 0x00000002
pub const VK_BUFFER_CREATE_SPARSE_ALIASED_BIT : Int = 0x00000004
pub const VK_BUFFER_CREATE_PROTECTED_BIT : Int = 0x00000008
pub const VK_BUFFER_CREATE_DEVICE_ADDRESS_CAPTURE_REPLAY_BIT : Int = 0x00000010
pub const VK_BUFFER_CREATE_FLAG_BITS_MAX_ENUM : Int = 0x7FFFFFFF

// Buffer usage flag bits - these are bitmask constants, not enum variants
// Use the VK_BUFFER_USAGE_*_BIT constants directly for bitmask operations

// Color component flags
pub const VK_COLOR_COMPONENT_R_BIT : Int = 0x00000001
pub const VK_COLOR_COMPONENT_G_BIT : Int = 0x00000002
pub const VK_COLOR_COMPONENT_B_BIT : Int = 0x00000004
pub const VK_COLOR_COMPONENT_A_BIT : Int = 0x00000008

// Compare op
pub enum VkCompareOp {
  VK_COMPARE_OP_NEVER
  VK_COMPARE_OP_LESS
  VK_COMPARE_OP_EQUAL
  VK_COMPARE_OP_LESS_OR_EQUAL
  VK_COMPARE_OP_GREATER
  VK_COMPARE_OP_NOT_EQUAL
  VK_COMPARE_OP_GREATER_OR_EQUAL
  VK_COMPARE_OP_ALWAYS
}

