///|
/// MoonBit Vulkan SDK Bindings - Extra Constants
/// Additional Vulkan constants not in other files

// Access flags
pub const VK_ACCESS_INDIRECT_COMMAND_READ_BIT : Int = 0x00000001
pub const VK_ACCESS_INDEX_READ_BIT : Int = 0x00000002
pub const VK_ACCESS_VERTEX_ATTRIBUTE_READ_BIT : Int = 0x00000004
pub const VK_ACCESS_UNIFORM_READ_BIT : Int = 0x00000008
pub const VK_ACCESS_INPUT_ATTACHMENT_READ_BIT : Int = 0x00000010
pub const VK_ACCESS_SHADER_READ_BIT : Int = 0x00000020
pub const VK_ACCESS_SHADER_WRITE_BIT : Int = 0x00000040
pub const VK_ACCESS_COLOR_ATTACHMENT_READ_BIT : Int = 0x00000080
pub const VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT : Int = 0x00000100
pub const VK_ACCESS_DEPTH_STENCIL_ATTACHMENT_READ_BIT : Int = 0x00000200
pub const VK_ACCESS_DEPTH_STENCIL_ATTACHMENT_WRITE_BIT : Int = 0x00000400
pub const VK_ACCESS_TRANSFER_READ_BIT : Int = 0x00000800
pub const VK_ACCESS_TRANSFER_WRITE_BIT : Int = 0x00001000
pub const VK_ACCESS_HOST_READ_BIT : Int = 0x00002000
pub const VK_ACCESS_HOST_WRITE_BIT : Int = 0x00004000
pub const VK_ACCESS_MEMORY_READ_BIT : Int = 0x00008000
pub const VK_ACCESS_MEMORY_WRITE_BIT : Int = 0x00010000

// Image aspect flags
pub const VK_IMAGE_ASPECT_COLOR_BIT : Int = 0x00000001
pub const VK_IMAGE_ASPECT_DEPTH_BIT : Int = 0x00000002
pub const VK_IMAGE_ASPECT_STENCIL_BIT : Int = 0x00000004
pub const VK_IMAGE_ASPECT_METADATA_BIT : Int = 0x00000008

// Surface transform flags
pub const VK_SURFACE_TRANSFORM_IDENTITY_BIT_KHR : Int = 0x00000001
pub const VK_SURFACE_TRANSFORM_ROTATE_90_BIT_KHR : Int = 0x00000002
pub const VK_SURFACE_TRANSFORM_ROTATE_180_BIT_KHR : Int = 0x00000004
pub const VK_SURFACE_TRANSFORM_ROTATE_270_BIT_KHR : Int = 0x00000008
pub const VK_SURFACE_TRANSFORM_HORIZONTAL_MIRROR_BIT_KHR : Int = 0x00000010
pub const VK_SURFACE_TRANSFORM_HORIZONTAL_MIRROR_ROTATE_90_BIT_KHR : Int = 0x00000020
pub const VK_SURFACE_TRANSFORM_HORIZONTAL_MIRROR_ROTATE_180_BIT_KHR : Int = 0x00000040
pub const VK_SURFACE_TRANSFORM_HORIZONTAL_MIRROR_ROTATE_270_BIT_KHR : Int = 0x00000080
pub const VK_SURFACE_TRANSFORM_INHERIT_BIT_KHR : Int = 0x00000100

// Composite alpha flags
pub const VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR : Int = 0x00000001
pub const VK_COMPOSITE_ALPHA_PRE_MULTIPLIED_BIT_KHR : Int = 0x00000002
pub const VK_COMPOSITE_ALPHA_POST_MULTIPLIED_BIT_KHR : Int = 0x00000004
pub const VK_COMPOSITE_ALPHA_INHERIT_BIT_KHR : Int = 0x00000008

// Cull mode flags (int values for bitmask operations)
pub const VK_CULL_MODE_NONE_VALUE : Int = 0
pub const VK_CULL_MODE_FRONT_BIT_VALUE : Int = 0x00000001
pub const VK_CULL_MODE_BACK_BIT_VALUE : Int = 0x00000002
pub const VK_CULL_MODE_FRONT_AND_BACK_VALUE : Int = 0x00000003

// Pipeline create flags
pub const VK_PIPELINE_CREATE_DISABLE_OPTIMIZATION_BIT : Int = 0x00000001
pub const VK_PIPELINE_CREATE_ALLOW_DERIVATIVES_BIT : Int = 0x00000002
pub const VK_PIPELINE_CREATE_DERIVATIVE_BIT : Int = 0x00000004
pub const VK_PIPELINE_CREATE_VIEW_INDEX_FROM_DEVICE_INDEX_BIT : Int = 0x00000008
